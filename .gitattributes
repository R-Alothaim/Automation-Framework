# Auto detect text files and perform LF normalization
* text=auto

# Java sources
*.java text diff=java

# Properties and config
*.properties text
*.xml text
*.yml text
*.yaml text
*.json text

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.xlsx binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.jar binary
